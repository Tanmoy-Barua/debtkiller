# =============================================================================
# Debt Destroyer — environment template
# Copy to `.env` (gitignored) and fill in real values. Never commit secrets.
# =============================================================================

# --- Supabase (browser-safe) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Legacy anon JWT key or new publishable key:
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Owner allowlist (optional). If set, only this email can sign in.
# Keep the real address in local/Vercel env — do not commit it.
# VITE_OWNER_EMAIL=owner@example.com

# Optional: shared app_state row id (default "shared")
# VITE_APP_STATE_ID=shared

# --- Plaid (server only on Vercel — never use a VITE_ prefix for secrets) ---
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox

# Required for "Refresh balances" after the first Plaid link:
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
