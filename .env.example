VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Either the legacy anon JWT key or the new publishable key works:
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Optional: change the shared row id (default is "shared")
# VITE_APP_STATE_ID=shared

# --- Plaid (server only — never use VITE_ prefix for secrets) ---
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox
# Required for Refresh balances after first link:
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
